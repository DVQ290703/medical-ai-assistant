# ============================================================
# Sao chép file này thành .env rồi điền giá trị thật.
#   cp .env.example .env      (Linux/macOS)
#   copy .env.example .env    (Windows)
# KHÔNG commit file .env thật lên git.
# ============================================================

# --- Hugging Face (tải model embedding/reranker) ---
# Lấy token tại: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Groq (LLM sinh câu trả lời, OpenAI-compatible) ---
# Lấy key free tại: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- RAG remote (model server chạy ở Colab/ngrok) ---
RAG_REMOTE_URL=https://your-ngrok-subdomain.ngrok-free.dev
# URL dự phòng (tùy chọn)
RAG_REMOTE_URL_BACKUP=
RAG_REMOTE_TOKEN=change-me

# --- Qdrant Cloud (vector store) ---
# Lấy tại: https://cloud.qdrant.io
QDRANT_URL=https://xxxxxxxx.region.gcp.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
# Timeout giây khi gọi Qdrant (mặc định 120)
QDRANT_TIMEOUT=120

# --- Qdrant self-hosted (chỉ dùng khi chạy local, thay cho QDRANT_URL) ---
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# --- Langfuse (observability, tùy chọn) ---
# Lấy tại: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- Server ---
# Cổng HTTP (Render sẽ tự set PORT khi deploy)
PORT=8000
